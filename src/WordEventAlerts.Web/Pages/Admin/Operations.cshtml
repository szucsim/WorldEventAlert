@page
@model WordEventAlerts.Web.Pages.Admin.OperationsModel
@{
    ViewData["Title"] = "Admin Operations";
}

<section class="hero-panel admin-hero">
    <p class="eyebrow">Admin Workflow</p>
    <h1>Delivery Operations Console</h1>
    <p>Inspect dead letters, trace delivery chains by correlation, and replay failed attempts.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="dashboard-grid">
    <section class="card-panel">
        <h2>Dead Letters</h2>
        <form method="post" asp-page-handler="LoadDeadLetters" class="form-stack compact">
            <button type="submit" class="btn btn-danger">Load Dead Letters</button>
        </form>
    </section>

    <section class="card-panel">
        <h2>Trace by Correlation</h2>
        <form method="post" asp-page-handler="SearchByCorrelation" class="form-stack compact">
            <label asp-for="CorrelationFilterInput">Correlation ID</label>
            <input asp-for="CorrelationFilterInput" class="form-control" />
            <button type="submit" class="btn btn-primary">Search Attempts</button>
        </form>
    </section>

    <section class="card-panel">
        <h2>Get Attempt by ID</h2>
        <form method="post" asp-page-handler="GetAttemptById" class="form-stack compact">
            <label asp-for="AttemptIdInput">Delivery Attempt ID</label>
            <input asp-for="AttemptIdInput" class="form-control" />
            <button type="submit" class="btn btn-outline-primary">Load Attempt</button>
        </form>
    </section>

    <section class="card-panel">
        <h2>Replay Attempt</h2>
        <form method="post" asp-page-handler="ReplayAttempt" class="form-stack compact">
            <label asp-for="ReplayAttemptIdInput">Source Attempt ID</label>
            <input asp-for="ReplayAttemptIdInput" class="form-control" />
            <button type="submit" class="btn btn-warning">Replay</button>
        </form>
    </section>
</div>

<div class="dashboard-grid tables">
    <section class="card-panel">
        <h3>Dead-Letter Attempts</h3>
        @if (Model.DeadLetters.Count == 0)
        {
            <p>No dead-letter attempts loaded.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Attempt ID</th>
                            <th>Outcome</th>
                            <th>Channel</th>
                            <th>Destination</th>
                            <th>Attempted UTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attempt in Model.DeadLetters)
                        {
                            <tr>
                                <td>@attempt.DeliveryAttemptId</td>
                                <td>@attempt.Outcome</td>
                                <td>@attempt.ChannelType</td>
                                <td>@attempt.Destination</td>
                                <td>@attempt.AttemptedAtUtc</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="card-panel">
        <h3>Correlation Search Results</h3>
        @if (Model.AttemptsByCorrelation.Count == 0)
        {
            <p>No attempts loaded for the current filter.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Attempt ID</th>
                            <th>Rule ID</th>
                            <th>Outcome</th>
                            <th>Failure</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attempt in Model.AttemptsByCorrelation)
                        {
                            <tr>
                                <td>@attempt.DeliveryAttemptId</td>
                                <td>@attempt.RuleId</td>
                                <td>@attempt.Outcome</td>
                                <td>@(attempt.FailureReason ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@if (Model.AttemptById is not null)
{
    <section class="card-panel">
        <h3>Attempt Details</h3>
        <dl class="detail-grid">
            <dt>Attempt ID</dt>
            <dd>@Model.AttemptById.DeliveryAttemptId</dd>

            <dt>Event ID</dt>
            <dd>@Model.AttemptById.EventId</dd>

            <dt>Rule ID</dt>
            <dd>@Model.AttemptById.RuleId</dd>

            <dt>Outcome</dt>
            <dd>@Model.AttemptById.Outcome</dd>

            <dt>Correlation ID</dt>
            <dd>@Model.AttemptById.CorrelationId</dd>
        </dl>
    </section>
}

@if (Model.ReplayResult is not null)
{
    <section class="card-panel accent-panel">
        <h3>Replay Result</h3>
        <dl class="detail-grid">
            <dt>Source Attempt</dt>
            <dd>@Model.ReplayResult.SourceAttemptId</dd>

            <dt>Replay Attempt</dt>
            <dd>@Model.ReplayResult.ReplayAttemptId</dd>

            <dt>Outcome</dt>
            <dd>@Model.ReplayResult.Outcome</dd>

            <dt>Correlation ID</dt>
            <dd>@Model.ReplayResult.CorrelationId</dd>
        </dl>
    </section>
}
